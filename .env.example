APP_NAME="Dify FastAPI RAG Tool Service"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
API_PREFIX=/api/v1
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ai_backend
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
REQUEST_TIMEOUT_SECONDS=60

RETRIEVAL_TOP_K=5
CHUNK_SIZE=900
CHUNK_OVERLAP=120
MAX_FILE_SIZE_MB=20
MAX_CONTEXT_CHUNKS=5

STORAGE_DIR=storage
UPLOAD_DIR=storage/uploads
